# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/spivdia

# ─── Auth / session (jose cookie) ─────────────────────────────────────────────
NEXTAUTH_SECRET=
# Публічна URL сайту (критично для листів і Google redirect)
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Email (лист підтвердження реєстрації, magic link) ───────────────────────
# https://resend.com — без цього листи друкуються в лог dev-сервера
RESEND_API_KEY=
EMAIL_FROM=СпівДія <onboarding@resend.dev>

# ─── Google OAuth («Продовжити з Google») ────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client
# Redirect URI: https://ВАШ_ДОМЕН/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Payments: Crypto ─────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_CERT_SN=

WHITEBIT_API_KEY=
WHITEBIT_SECRET_KEY=

# ─── Payments: P2P ────────────────────────────────────────────────────────────
MONO_JAR_ID=
P2P_CARD_NUMBER=

# ─── Internal Economy ─────────────────────────────────────────────────────────
# 1 USD = N СпівМонет
TOKEN_RATE=100
