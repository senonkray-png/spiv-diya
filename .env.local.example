# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/spivdia
# Vercel / Neon: додайте той самий URL у Project → Environment Variables; для pooler часто потрібен sslmode=require

# ─── Auth / session (jose cookie) ─────────────────────────────────────────────
NEXTAUTH_SECRET=
# Публічна URL сайту — обовʼязково для посилань у листах (підтвердження пошти) на Vercel
# Приклад: https://spiv-diya.vercel.app або ваш домен
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Email (підтвердження реєстрації) ─────────────────────────────────────────
# Порядок відправки: EMAIL_WEBHOOK_URL → Resend (RESEND_API_KEY) → Supabase Edge → (dev) консоль
#
# Варіант A — напряму Resend з Vercel:
RESEND_API_KEY=
EMAIL_FROM=СпівДія <onboarding@resend.dev>
#
# Варіант B — Supabase Edge Function `send-auth-email` (див. supabase/functions/send-auth-email/)
# У Vercel додайте URL проєкту та service role; у Supabase Secrets функції — RESEND_API_KEY (або змініть функцію під SMTP).
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Для виклику Edge Functions (заголовок apikey); зазвичай уже є з інтеграції Vercel ↔ Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Ім’я функції, якщо не send-auth-email:
# SUPABASE_SEND_EMAIL_FUNCTION=send-auth-email
#
# Варіант C — власний HTTPS endpoint (наприклад ваша Edge Function з іншою адресою):
# EMAIL_WEBHOOK_URL=https://...
# EMAIL_WEBHOOK_SECRET=

# ─── Google OAuth («Продовжити з Google») ────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client
# Redirect URI: https://ВАШ_ДОМЕН/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Payments: Crypto ─────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_CERT_SN=

WHITEBIT_API_KEY=
WHITEBIT_SECRET_KEY=

# ─── Payments: P2P ────────────────────────────────────────────────────────────
MONO_JAR_ID=
P2P_CARD_NUMBER=

# ─── Internal Economy ─────────────────────────────────────────────────────────
# 1 USD = N СпівМонет
TOKEN_RATE=100
