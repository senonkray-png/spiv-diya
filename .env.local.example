# ─── AI ───────────────────────────────────────────────────────────────────────
# Класифікація товарів на головній маркетплейсу (категорія каталогу): якщо ключ задано — Claude; інакше евристика за ключовими словами.
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/spivdia
# Vercel / Neon: додайте той самий URL у Project → Environment Variables; для pooler часто потрібен sslmode=require

# ─── Auth / session (jose cookie) ─────────────────────────────────────────────
NEXTAUTH_SECRET=
# Публічна URL сайту — обовʼязково для посилань у листах (підтвердження пошти) на Vercel
# Приклад: https://spiv-diya.vercel.app або ваш домен
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Email (підтвердження реєстрації) ─────────────────────────────────────────
# За замовчуванням перевірочний лист вимкнено. Щоб увімкнути лист після реєстрації:
#   SKIP_EMAIL_VERIFICATION=0
# і налаштуйте відправку нижче (webhook або Supabase Edge + SMTP).
#
# Варіант A — Supabase Edge `send-auth-email` (SMTP; секрети лише в Supabase → Edge Functions → Secrets):
#   SMTP_HOST, SMTP_PORT (587), SMTP_SECURE (true для 465), SMTP_USER, SMTP_PASS, EMAIL_FROM
# У Vercel:
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SEND_EMAIL_FUNCTION=send-auth-email
#
# Варіант B — власний HTTPS endpoint (JSON body: { to, subject, html, text? }):
# EMAIL_WEBHOOK_URL=https://...
# EMAIL_WEBHOOK_SECRET=

# ─── Google OAuth («Продовжити з Google») ────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client
# Redirect URI: https://ВАШ_ДОМЕН/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Payments: Crypto ─────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_CERT_SN=

WHITEBIT_API_KEY=
WHITEBIT_SECRET_KEY=

# ─── Payments: P2P ────────────────────────────────────────────────────────────
MONO_JAR_ID=
P2P_CARD_NUMBER=

# Скільки СпівМонет за 1 ₴ при оформленні замовлень і відображенні перерахунку (цілі числа, округлення вгору).
NEXT_PUBLIC_TOKENS_PER_1_UAH=1

# ─── Імпорт товарів з зовнішнього сайту ───────────────────────────────────────
# Ліміти збору URL / сторінок (статичний HTML, без браузера).
IMPORT_MAX_URLS=600
IMPORT_MAX_FETCH=220
IMPORT_FETCH_CONCURRENCY=5
# Скільки позицій за один commit (макс. 500).
IMPORT_COMMIT_MAX=300
#
# Режим Puppeteer у API (лише Node/VPS; на типовому Vercel без Chromium не працює):
# IMPORT_ENABLE_HEADLESS=1
# Щоб показати в UI блок з селекторами, додайте і публічний прапорець (потребує rebuild):
# NEXT_PUBLIC_IMPORT_HEADLESS=1